# ==============================================================================
# AI Log Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Azure OpenAI
# ------------------------------------------------------------------------------
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# ------------------------------------------------------------------------------
# Azure Log Analytics Workspaces
# ------------------------------------------------------------------------------
PROPROCTOR_WORKSPACE_ID=<log-analytics-workspace-id-for-proproctor>
INFRA_WORKSPACE_ID=<log-analytics-workspace-id-for-infra>

# ------------------------------------------------------------------------------
# Azure Cosmos DB
# ------------------------------------------------------------------------------
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
# Optional: leave blank to use DefaultAzureCredential (managed identity / az login)
COSMOS_KEY=

# ------------------------------------------------------------------------------
# API Settings (optional — defaults shown)
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000
ANALYZE_TIMEOUT_SECONDS=300
MAX_AGENT_ITERATIONS=10
TOOL_RESPONSE_MAX_TOKENS=40000
LOG_LEVEL=INFO
